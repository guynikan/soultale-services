PORT=3000
NODE_ENV=development
DATABASE_URL=postgresql://user:password@localhost:5432/soultale
# Inline JSON (uma linha) OU caminho para o arquivo baixado do Console:
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_PATH=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
ALLOWED_ORIGINS=*

# Origem pública do CDN/R2 (sem barra no final). Imagens do baralho: {base}/deck/v1/{imageId}.png
DECK_ASSETS_PUBLIC_BASE_URL=

# Token da API Cloudflare (cfat_…), se usar Wrangler/scripts contra a API
CLOUDFLARE_API_TOKEN=

# New Relic APM — chave em newrelic.com > (account) > API Keys > INGEST - LICENSE
NEW_RELIC_LICENSE_KEY=
NEW_RELIC_APP_NAME=SoulTale API
